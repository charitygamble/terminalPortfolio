---
layout: base.njk
eleventyNavigation:
  key: Labs
  parent: Home
---
<h2>~/labs</h2>
<p>Total artifacts recovered: {{ collections.labs | length }}</p>

<table class="terminal-table">
  <thead>
    <tr>
      <th>Date</th>
      <th>File</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    {%- for post in collections.labs | reverse -%}
    <tr>
      <td>{{ post.date | dateString }}</td>
      <td><a href="{{ post.url }}">./{{ post.fileSlug }}.sh</a></td>
      <td><span class="status">[READ_ONLY]</span></td>
    </tr>
    {%- endfor -%}
  </tbody>
</table>