<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta http-equiv=""X-UA-Compatible" content="IE=edge">
        <title>Charity Gamble - {{ title }}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">   
        <link href="/assets/css/style.css" rel="stylesheet">
        <script src="https://kit.fontawesome.com/7ee24494c8.js" crossorigin="anonymous"></script>
    </head>
    <body>
      <div class="desktop-sidebar">
    <div class="icon-group">
        <a href="#terminal"><i class="fa-solid fa-terminal"></i></a>
        <span>Terminal</span>
    </div>
    <div class="icon-group">
        <a href="#"><i class="fa-solid fa-folder-open"></i></a><br>
        <span>Home</span>
    </div>
    <div class="icon-group">
        <i class="fa-solid fa-shield-halved"></i><br>
        <span>Tools</span>
    </div>
        <div class="icon-group">
        <a href="/assets/cgambleresume.pdf" download="cgambleresume.pdf" class="icon-group"><i class="fa-regular fa-file"></i></a><br>
        <span>Download Résumé</span>
    </div>
</div>
      <div class="crt-overlay"></div>
        <div id="terminal" class="terminal-container">
  <header class="terminal-bar">
  <div class="controls">
    <span class="dot red"></span>
    <span class="dot yellow"></span>
    <span class="dot green"></span>
  </div>
          <button class="accessibility-toggle" aria-label="Toggle CRT Effects">
  [ DISABLE_VISUAL_EFFECTS ]
</button>
  <div class="terminal-path">
  guest@cgambledev:~
  {# Defensive check to prevent 'Node does not exist' fatal crashes #}
{% if eleventyNavigation and eleventyNavigation.key %}
  {% set navPages = collections.all | eleventyNavigationBreadcrumb(eleventyNavigation.key) if collections.all | eleventyNavigationBreadcrumb(eleventyNavigation.key) else [] %}
  {% for entry in navPages %}
    <a href="{{ entry.url }}">{{ entry.title }}</a> /
  {% endfor %}
{% endif %}
</div>
</header>
  <nav class="terminal-nav">
    <ul>
      <li><a href="/">[ <span class="cmd">cd</span> /home ]</a></li>
      <li><a href="/about/">[ whomai ]</a></li>
      <li><a href="/neofetch/">[ neofetch ]</a></li>
      <li><a href="/projects/">[ <span class="cmd">cd</span> /projects ]</a></li>
      <li><a href="/labs/">[ <span class="cmd">cd</span> /lab-notes ]</a></li>
      <li><a href="/contact/">[ <span class="cmd">cd</span> /contact ]</a></li>
    </ul>
  </nav>

  <main class="terminal-body">
    {% if page.url == "/main.html" %}
    <div class="login-banner">
            <pre>
****************************************************************
* WARNING: AUTHORIZED ACCESS ONLY                              *
* Kali Linux and the Dragon logo are trademarks of OffSec.     *
* This site is a personal project and is not affiliated with   *
* or endorsed by Offsec.                                       *
****************************************************************
            </pre>
        </div>
        {% endif %}
    {{ content | safe }}
    <span class="cursor">█</span>
  </main>
</div>
<script src="/assests/js/copyClipboard.js"></script>
<script src="/assets/js/safeMode.js"></script>
</body>
</html>