---
layout: base.njk
---
<article class="lab-note">
  <header class="note-header">
    <div class="stat-line">FILE: {{ title | lower | replace(" ", "_") }}.md</div>
    <div class="stat-line">DATE: {{ date | dateString }}</div>
    <div class="stat-line">TAGS: [ {{ tags | join(", ") }} ]</div>
    <div class="stat-line">USER: charity@cgambledev</div>
    <hr class="header-divider">
  </header>

  <section class="note-content">
    {{ content | safe }}
  </section>

  <footer class="note-footer">
    <div class="end-of-file">(END)</div>
    <nav class="post-navigation">
      <a href="/projects/">[ BACK_TO_DIRECTORY ]</a>
    </nav>
  </footer>
</article>